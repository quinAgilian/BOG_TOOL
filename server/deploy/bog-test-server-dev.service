[Unit]
Description=BOG Production Test Data Server (Dev)
After=network.target

[Service]
Type=simple
User=root
TimeoutStopSec=10
WorkingDirectory=/opt/bog-test-server-dev
Environment="PATH=/opt/bog-test-server-dev/.venv/bin"
Environment="BOG_DB_PATH=/var/lib/bog-test-server-dev/bog_test.db"
Environment="BOG_ENV=dev"
Environment="PYTHONUNBUFFERED=1"
ExecStart=/opt/bog-test-server-dev/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8001 --loop asyncio --app-dir /opt/bog-test-server-dev
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
