[Unit]
Description=BOG Production Test Data Server
After=network.target

[Service]
Type=simple
User=root
TimeoutStopSec=10
WorkingDirectory=/opt/bog-test-server
Environment="PATH=/opt/bog-test-server/.venv/bin"
Environment="BOG_DB_PATH=/var/lib/bog-test-server/bog_test.db"
Environment="PYTHONUNBUFFERED=1"
ExecStart=/opt/bog-test-server/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000 --loop asyncio --app-dir /opt/bog-test-server
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
