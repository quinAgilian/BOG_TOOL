{
  "schema_version": 1,
  "rules_version": "BOG-SOP-2026.03",
  "meta": {
    "project_name": "BOG-P02",
    "author": "",
    "created_at": "",
    "updated_at": "",
    "notes": ""
  },
  "global": {
    "step_interval_ms": 100,
    "skip_factory_reset_and_disconnect_on_fail": true,
    "failure_policy": {
      "fatal_default": [
        "step_verify_firmware"
      ],
      "overrides": {
      }
    }
  },
  "environment": {
    "ble_scan": {
      "rssi_filter_enabled": false,
      "min_rssi_dbm": -100,
      "name_whitelist_enabled": true,
      "name_whitelist_keywords": [
        "CO2",
        "BOG"
      ],
      "name_blacklist_keywords": [
        "mac",
        "iphone"
      ]
    }
  },
  "steps": [
    {
      "id": "step_connect",
      "enabled": true,
      "order": 1,
      "fatal_on_failure": true,
      "config": {
        "bluetooth_permission_wait_seconds": 0.0
      }
    },
    {
      "id": "step_verify_firmware",
      "enabled": true,
      "order": 2,
      "fatal_on_failure": true,
      "config": {
        "allowed_bootloader_versions": [
          "2"
        ],
        "allowed_firmware_versions": [],
        "allowed_hardware_versions": [
          "P02V02R01"
        ],
        "firmware_upgrade_enabled": false
      }
    },
    {
      "id": "step_read_rtc",
      "enabled": true,
      "order": 3,
      "fatal_on_failure": null,
      "config": {
        "pass_threshold_seconds": 2.0,
        "fail_threshold_seconds": 5.0,
        "write_enabled": true,
        "write_retry_count": 3,
        "read_timeout_seconds": 2.0
      }
    },
    {
      "id": "step_read_pressure",
      "enabled": true,
      "order": 4,
      "fatal_on_failure": null,
      "config": {
        "closed_min_mbar": 1000,
        "closed_max_mbar": 1350,
        "open_min_mbar": 1000,
        "open_max_mbar": 1500,
        "diff_check_enabled": true,
        "diff_min_mbar": 0,
        "diff_max_mbar": 400,
        "fail_retry_confirm_enabled": true
      }
    },
    {
      "id": "step_disable_diag",
      "enabled": true,
      "order": 5,
      "fatal_on_failure": null,
      "config": {
        "wait_seconds": 2.0,
        "expected_gas_status_values": [
          1
        ],
        "poll_timeout_seconds": 3.0,
        "poll_enabled": true
      }
    },
    {
      "id": "step_gas_system_status",
      "enabled": true,
      "order": 6,
      "fatal_on_failure": null,
      "config": {
      }
    },
    {
      "id": "step_gas_leak_closed",
      "enabled": true,
      "order": 7,
      "fatal_on_failure": null,
      "config": {
        "pre_close_duration_seconds": 10,
        "post_close_duration_seconds": 15,
        "interval_seconds": 0.5,
        "drop_threshold_mbar": 15,
        "start_pressure_min_mbar": 1300,
        "require_pipeline_ready_confirm": true,
        "require_valve_closed_confirm": true,
        "limit_source": "phase1_avg",
        "limit_floor_bar": 0.0,
        "phase4_enabled": true,
        "phase4_monitor_duration_seconds": 15,
        "phase4_drop_within_seconds": 5,
        "phase4_pressure_below_mbar": 100,
        "skip_closed_when_open_passes": false
      }
    },
    {
      "id": "step_valve",
      "enabled": true,
      "order": 8,
      "fatal_on_failure": null,
      "config": {
        "open_timeout_seconds": 5.0
      }
    },
    {
      "id": "step_reset",
      "enabled": false,
      "order": 9,
      "fatal_on_failure": null,
      "config": {
      }
    },
    {
      "id": "step_factory_reset",
      "enabled": true,
      "order": 10,
      "fatal_on_failure": true,
      "config": {
      }
    },
    {
      "id": "step_ota",
      "enabled": true,
      "order": 11,
      "fatal_on_failure": null,
      "config": {
      }
    },
    {
      "id": "step_disconnect",
      "enabled": true,
      "order": 12,
      "fatal_on_failure": true,
      "config": {
      }
    }
  ]
}

